# ============================================================
# ASIOE — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=production
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_64_CHAR_HEX_SECRET

# ── LLM — Groq API ─────────────────────────────────────────────────────────────
# Get free API key at: https://console.groq.com/
GROQ_API_KEY=gsk_REPLACE_WITH_YOUR_GROQ_API_KEY

# ── PostgreSQL ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=asioe_pg_REPLACE_WITH_STRONG_PASSWORD

# ── Neo4j ───────────────────────────────────────────────────────────────────────
# Must be at least 8 characters
NEO4J_PASSWORD=asioe_neo4j_REPLACE

# ── Redis ───────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=asioe_redis_REPLACE

# ── Optional: Cloud Deployment ─────────────────────────────────────────────────
# ALLOWED_ORIGINS=["https://your-domain.com"]
# SENTRY_DSN=https://your-sentry-dsn
